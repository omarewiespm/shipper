    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "chart.js": "^4.5.1",
    "jspdf": "^2.5.2",
    "leaflet": "^1.9.4",
    "lucide-angular": "^1.0.0",
    "ng2-charts": "^10.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.18",
    "@angular/cli": "^21.2.18",
    "@angular/compiler-cli": "^21.2.0",
    "@types/leaflet": "^1.9.21",
    "angular-cli-ghpages": "^3.1.0",
